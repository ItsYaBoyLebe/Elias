# ─────────────────────────────────────────────────────────────
#  Template for secrets.  Copy this file to `.env` and fill in real
#  values.  `.env` is gitignored and never committed — only this
#  template (with placeholder values) lives in the repo.
#
#      cp .env.example .env
#
#  Never put a real secret in this file.
# ─────────────────────────────────────────────────────────────

# Supabase (or whichever backend you choose for bookings/data)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key   # backend only — keep secret

# Payments (if/when you add online deposits for rentals)
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Contact form / email delivery
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
